# Application
APP_NAME=Enterprise RAG Assistant
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Authentication (generate with: openssl rand -hex 32)
SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL
POSTGRES_DB=enterprise_rag
POSTGRES_USER=enterprise_rag
POSTGRES_PASSWORD=change-me-before-production
DATABASE_URL=postgresql+psycopg://enterprise_rag:change-me-before-production@db:5432/enterprise_rag

# Redis
REDIS_URL=redis://redis:6379/0

# Document uploads
DOCUMENT_STORAGE_PATH=/data/documents
MAX_UPLOAD_SIZE_MB=20

# Reverse proxy host port
HTTP_PORT=8000
