# Application
APP_NAME=Enterprise RAG Assistant
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_VERSION=0.3.0
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Authentication (generate with: openssl rand -hex 32)
SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL
POSTGRES_DB=enterprise_rag
POSTGRES_USER=enterprise_rag
POSTGRES_PASSWORD=change-me-before-production
DATABASE_URL=postgresql+psycopg://enterprise_rag:change-me-before-production@db:5432/enterprise_rag

# Redis
REDIS_URL=redis://redis:6379/0

# Document uploads
DOCUMENT_STORAGE_PATH=/data/documents
MAX_UPLOAD_SIZE_MB=20
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Chunk embeddings (vectors are not persisted until Milvus integration)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=1024

# Milvus vector persistence
MILVUS_URI=http://milvus:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=knowledgehub_chunks
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=HNSW
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=200
MILVUS_PORT=19530

# Reverse proxy host port
HTTP_PORT=8000
