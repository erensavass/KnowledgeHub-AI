# Application
APP_NAME=KnowledgeHub AI
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173
TRUSTED_HOSTS=localhost,127.0.0.1,testserver

# Authentication (generate with: openssl rand -hex 32)
SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL
POSTGRES_DB=enterprise_rag
POSTGRES_USER=enterprise_rag
POSTGRES_PASSWORD=change-me-before-production
DATABASE_URL=postgresql+psycopg://enterprise_rag:change-me-before-production@db:5432/enterprise_rag

# Redis
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT=10
UPLOAD_RATE_LIMIT=10
SEARCH_RATE_LIMIT=60
RAG_RATE_LIMIT=20
STREAM_RATE_LIMIT=20
DEPENDENCY_HEALTH_TIMEOUT_SECONDS=2

# Document uploads
DOCUMENT_STORAGE_PATH=/data/documents
MAX_UPLOAD_SIZE_MB=20
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Chunk embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=1024
HF_HOME=/data/model-cache

# Milvus vector persistence
MILVUS_URI=http://milvus:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=knowledgehub_chunks
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=HNSW
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=200
MILVUS_PORT=19530
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-a-long-random-password

# Semantic retrieval
SEARCH_DEFAULT_TOP_K=5
SEARCH_MAX_TOP_K=20
SEARCH_SCORE_THRESHOLD=0.0

# Grounded answer generation
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_PORT=11434
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_CONTEXT_CHUNKS=8
LLM_REQUEST_TIMEOUT_SECONDS=60
RAG_MAX_QUERY_LENGTH=2000
RAG_MAX_CONTEXT_CHARACTERS=24000
RAG_CITATION_EXCERPT_LENGTH=300

# Persistent conversations and streaming
CONVERSATION_HISTORY_MAX_MESSAGES=8
CONVERSATION_HISTORY_MAX_CHARACTERS=12000
CONVERSATION_TITLE_MAX_LENGTH=120
CONVERSATION_PAGE_SIZE_DEFAULT=20
CONVERSATION_PAGE_SIZE_MAX=100
MESSAGE_MAX_LENGTH=4000
STREAM_HEARTBEAT_SECONDS=15

# Reverse proxy host port
HTTP_PORT=8000

# Frontend (Vite values are embedded at image build time)
VITE_API_BASE_URL=/api
