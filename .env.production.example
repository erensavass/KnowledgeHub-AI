# Copy to a secret-managed production environment; never commit populated values.
APP_NAME=KnowledgeHub AI
APP_ENVIRONMENT=production
APP_DEBUG=false
APP_VERSION=1.0.0
LOG_LEVEL=INFO
SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
CORS_ALLOWED_ORIGINS=https://knowledge.example.com
TRUSTED_HOSTS=knowledge.example.com

POSTGRES_DB=knowledgehub
POSTGRES_USER=knowledgehub
POSTGRES_PASSWORD=generate-a-unique-database-password
DATABASE_URL=postgresql+psycopg://knowledgehub:URL_ENCODED_PASSWORD@db:5432/knowledgehub
REDIS_URL=redis://redis:6379/0
MINIO_ROOT_USER=generate-a-nondefault-user
MINIO_ROOT_PASSWORD=generate-a-unique-minio-password

RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT=10
UPLOAD_RATE_LIMIT=10
SEARCH_RATE_LIMIT=60
RAG_RATE_LIMIT=20
STREAM_RATE_LIMIT=20
DEPENDENCY_HEALTH_TIMEOUT_SECONDS=2

DOCUMENT_STORAGE_PATH=/data/documents
MAX_UPLOAD_SIZE_MB=20
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=1024
HF_HOME=/data/model-cache
MILVUS_URI=http://milvus:19530
MILVUS_TOKEN=
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OPENAI_API_KEY=
HTTP_PORT=8000
VITE_API_BASE_URL=/api
